# System
units            real
atom_style       full
dimension        3
newton           on
boundary         p p p

# Styles
pair_style	lj/class2/coul/long 9.5 10.0
kspace_style    ewald 1.0e-4
bond_style	class2
angle_style	class2
dihedral_style	class2
improper_style	class2
pair_modify	mix sixthpower tail yes
special_bonds	lj/coul 0 0 1


# Data file input
read_data    setup.data

# Settings
dielectric       1.0
neighbor         2.0 bin
neigh_modify     delay 0 every 1 check yes
timestep         1.0
run_style        verlet

# Output
group extr_ends id 1 2 3 4 5 6 7 22 23 24 25 26 27 28 52 53 54 55 57 58 59 60
delete_atoms group extr_ends bond yes
reset_atoms id sort yes
thermo_style  custom step temp pe ke etotal epair ebond eangle edihed
thermo           500

# MD step
minimize 1.0e-3 1.0e-5 600 400000   # minimization beforehand is optional

write_data setup_removed.lmps
